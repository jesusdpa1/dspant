{
  "editor.rulers": [
    88
  ],
  "ruff.nativeServer": "on",
  "editor.wordWrapColumn": 80,
  "editor.wordWrap": "wordWrapColumn",
  // Ruff configuration
  "ruff.lineLength": 88,
  "ruff.lint.select": [
    "E",
    "F",
    "W",
    "C"
  ],
  "ruff.organizeImports": true,
  "[python]": {
    "editor.codeActionsOnSave": {
      "source.organizeImports.ruff": "explicit"
    },
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  // Python interpreter path
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  
  // Rust with PyO3 - explicit environment variables
  "rust-analyzer.cargo.extraEnv": {
    "PYO3_PYTHON": "${workspaceFolder}/.venv/bin/python",
    "PYTHON_SYS_EXECUTABLE": "${workspaceFolder}/.venv/bin/python"
  },
  
  // Environment variables for integrated terminal - platform-specific
  "terminal.integrated.env.windows": {
    "PYO3_PYTHON": "${workspaceFolder}/.venv/Scripts/python.exe"
  },
  "terminal.integrated.env.linux": {
    "PYO3_PYTHON": "${workspaceFolder}/.venv/bin/python"
  },
  "terminal.integrated.env.osx": {
    "PYO3_PYTHON": "${workspaceFolder}/.venv/bin/python"
  }
}